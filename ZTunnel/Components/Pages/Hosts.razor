@page "/hosts"
@rendermode InteractiveServer
@inject TunnelConfigStore Store
@inject SshTunnelService Tunnel
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>ZTunnel · SSH Hosts</PageTitle>

<div class="zt-toolbar">
    <div class="zt-toolbar-left">
        <span class="zt-status-chip ok"><span class="zt-dot"></span>@Tunnel.ConnectedCount connected</span>
    </div>
    <div class="zt-toolbar-right">
        <button type="button" class="btn btn-primary" @onclick="AddHost">+ Add SSH host</button>
    </div>
</div>

@if (!Store.Hosts.Any())
{
    <div class="zt-empty">
        <div class="zt-empty-icon">🖧</div>
        <div class="zt-empty-title">No SSH hosts yet</div>
        <div class="zt-empty-sub">Add your first host to start tunneling.</div>
        <button type="button" class="btn btn-primary mt-3" @onclick="AddHost">Add your first host</button>
    </div>
}
else
{
    <div class="zt-forward-list">
        @foreach (var h in Store.Hosts)
        {
            var rt = Tunnel.GetRuntime(h.Id);
            <div class="zt-forward-card">
                <div class="zt-forward-head">
                    <div>
                        <div class="zt-forward-name">
                            @h.Name
                            @if (h.AutoConnect)
                            {
                                <span class="zt-badge local">AUTO</span>
                            }
                        </div>
                        <div class="zt-forward-route">
                            <code>@h.Username@@@h.Host:@h.Port</code>
                        </div>
                        <div class="zt-forward-route">
                            @h.Forwards.Count(f => f.Enabled) / @h.Forwards.Count forwards enabled
                        </div>
                    </div>
                    <div class="zt-forward-status">
                        <span class="zt-status-chip @StatusOf(rt.Status)">
                            <span class="zt-dot"></span>@rt.Status
                        </span>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(rt.LastError))
                {
                    <div class="zt-alert err mt-2">⚠ @rt.LastError</div>
                }
                <div class="zt-forward-actions">
                    <a class="btn btn-sm btn-outline-secondary" href="hosts/@h.Id">Configure</a>
                    @if (Tunnel.IsConnected(h.Id))
                    {
                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => Tunnel.ReconnectHostAsync(h.Id)">Reconnect</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => Tunnel.DisconnectHostAsync(h.Id)">Disconnect</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-sm btn-primary" @onclick="() => Tunnel.ConnectHostAsync(h.Id)" disabled="@(!h.IsValid)">Connect</button>
                    }
                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => Delete(h)">Delete</button>
                </div>
            </div>
        }
    </div>
}

@code {
    protected override void OnInitialized() => Tunnel.StateChanged += OnChanged;
    private async void OnChanged() => await InvokeAsync(StateHasChanged);

    private string StatusOf(string s) => s switch
    {
        "Connected" => "ok",
        "Connecting" or "Reconnecting" => "warn",
        "Error" => "err",
        _ => ""
    };

    private void AddHost()
    {
        var host = new SshHost { Name = $"Host #{Store.Hosts.Count + 1}" };
        Store.AddHost(host);
        Nav.NavigateTo($"hosts/{host.Id}");
    }

    private async Task Delete(SshHost h)
    {
        await Tunnel.DisconnectHostAsync(h.Id);
        Store.RemoveHost(h.Id);
    }

    public void Dispose() => Tunnel.StateChanged -= OnChanged;
}
